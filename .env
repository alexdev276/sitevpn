APP_NAME=VPN Service
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_LOG_FILE=./var/app.log
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true

DATABASE_URL=postgresql+asyncpg://vpn:vpn@db:5432/vpn
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=change-me
JWT_REFRESH_SECRET_KEY=change-me-too
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
REFRESH_COOKIE_NAME=refresh_token
SECURE_COOKIES=false

BRUTE_FORCE_MAX_ATTEMPTS=5
BRUTE_FORCE_BLOCK_MINUTES=15

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_API_BASE=https://api.stripe.com
STRIPE_SUCCESS_URL=http://localhost:3000/payments/success
STRIPE_CANCEL_URL=http://localhost:3000/payments/cancel

REMNAWAVE_BASE_URL=https://example.remna.studio
REMNAWAVE_API_KEY=change-me
REMNAWAVE_INTERNAL_SQUAD_ID=internal-squad-id

EMAIL_FROM=noreply@example.com
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=

DEFAULT_TRAFFIC_LIMIT_BYTES=107374182400
ADMIN_EMAIL=admin@example.com

